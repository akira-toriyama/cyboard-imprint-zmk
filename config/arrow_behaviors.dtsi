// 矢印 mod-morph (_up/_down/_left/_right) + 対応 hold-tap (_*_ht)
// behaviors { } ブロック内に #include して使う
// ARROW_BEHAVIOR マクロは keymap_defines.h で定義

    ARROW_BEHAVIOR(_up,    UP_ARROW_LAYER,    UP_ARROW,    KEY_POSITION_LEFT_ARROW, KEY_POSITION_RIGHT_ARROW)
    ARROW_BEHAVIOR(_down,  DOWN_ARROW_LAYER,  DOWN_ARROW,  KEY_POSITION_LEFT_ARROW, KEY_POSITION_RIGHT_ARROW)
    ARROW_BEHAVIOR(_left,  LEFT_ARROW_LAYER,  LEFT_ARROW,  KEY_POSITION_DOWN_ARROW, KEY_POSITION_RIGHT_ARROW)
    ARROW_BEHAVIOR(_right, RIGHT_ARROW_LAYER, RIGHT_ARROW, KEY_POSITION_DOWN_ARROW, KEY_POSITION_LEFT_ARROW)
