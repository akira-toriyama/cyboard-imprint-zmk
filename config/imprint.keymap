    en_dq: en_dq { // "
      compatible = "zmk,behavior-macro";
      #binding-cells = <0>;
      bindings = <&macro_tap &kp EIJI>, <&macro_press &kp DOUBLE_QUOTES>, <&macro_pause_for_release>, <&macro_release &kp DOUBLE_QUOTES>;
    };
    en_sq: en_sq { // '
      compatible = "zmk,behavior-macro";
      #binding-cells = <0>;
