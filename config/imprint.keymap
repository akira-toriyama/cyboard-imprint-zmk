      #binding-cells = <0>;
      bindings = <&macro_tap &kp EIJI>, <&macro_press &kp BACKSLASH>, <&macro_pause_for_release>, <&macro_release &kp BACKSLASH>;
    };

    // EIJI 切替 → 記号キー（SYMBOL2_LAYER 用）
    en_caret: en_caret { // ^
      compatible = "zmk,behavior-macro";
      #binding-cells = <0>;
      bindings = <&macro_tap &kp EIJI>, <&macro_press &kp CARET>, <&macro_pause_for_release>, <&macro_release &kp CARET>;
    };
    en_lt: en_lt { // <
      compatible = "zmk,behavior-macro";
      #binding-cells = <0>;
      bindings = <&macro_tap &kp EIJI>, <&macro_press &kp LESS_THAN>, <&macro_pause_for_release>, <&macro_release &kp LESS_THAN>;
    };
    en_gt: en_gt { // >
      compatible = "zmk,behavior-macro";
      #binding-cells = <0>;
      bindings = <&macro_tap &kp EIJI>, <&macro_press &kp GREATER_THAN>, <&macro_pause_for_release>, <&macro_release &kp GREATER_THAN>;
    };
    en_lbkt: en_lbkt { // [
      compatible = "zmk,behavior-macro";
      #binding-cells = <0>;
      bindings = <&macro_tap &kp EIJI>, <&macro_press &kp LEFT_BRACKET>, <&macro_pause_for_release>, <&macro_release &kp LEFT_BRACKET>;
    };
    en_rbkt: en_rbkt { // ]
      compatible = "zmk,behavior-macro";
