    en_grave: en_grave { // `
      compatible = "zmk,behavior-macro";
      #binding-cells = <0>;
      bindings = <&macro_tap &kp EIJI>, <&macro_press &kp GRAVE>, <&macro_pause_for_release>, <&macro_release &kp GRAVE>;
    };
    en_slash: en_slash { // /
