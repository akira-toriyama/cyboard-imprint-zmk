// EIJI 切替 → 数字 / 記号キー用の専用 behavior 群
// macros { } ブロック内に #include して使う
// EN_MACRO マクロは keymap_defines.h で定義
// keymap-drawer 上の表示は keymap_drawer.config.yaml の raw_binding_map で設定

    // EIJI 切替 → 数字キー（NUM_LAYER 用）
    EN_MACRO(en0, N0)
    EN_MACRO(en1, N1)
    EN_MACRO(en2, N2)
    EN_MACRO(en3, N3)
    EN_MACRO(en4, N4)
    EN_MACRO(en5, N5)
    EN_MACRO(en6, N6)
    EN_MACRO(en7, N7)
    EN_MACRO(en8, N8)
    EN_MACRO(en9, N9)

    // EIJI 切替 → 記号キー（SYMBOL1_LAYER 用）
    EN_MACRO(en_under, UNDERSCORE)
    EN_MACRO(en_pipe,  PIPE)
    EN_MACRO(en_amp,   AMPERSAND)
    EN_MACRO(en_excl,  EXCLAMATION)
    EN_MACRO(en_q,     QUESTION)
    EN_MACRO(en_hash,  HASH)
    EN_MACRO(en_comma, COMMA)
    EN_MACRO(en_dot,   PERIOD)
    EN_MACRO(en_semi,  SEMICOLON)
    EN_MACRO(en_colon, COLON)
    EN_MACRO(en_at,    AT_SIGN)
    EN_MACRO(en_dq,    DOUBLE_QUOTES)
    EN_MACRO(en_sq,    SINGLE_QUOTE)
    EN_MACRO(en_grave, GRAVE)
    EN_MACRO(en_slash, SLASH)
    EN_MACRO(en_bsl,   BACKSLASH)

    // EIJI 切替 → 記号キー（SYMBOL2_LAYER 用）
    EN_MACRO(en_caret,  CARET)
    EN_MACRO(en_lt,     LESS_THAN)
    EN_MACRO(en_gt,     GREATER_THAN)
    EN_MACRO(en_lbkt,   LEFT_BRACKET)
    EN_MACRO(en_rbkt,   RIGHT_BRACKET)
    EN_MACRO(en_eq,     EQUAL)
    EN_MACRO(en_plus,   PLUS)
    EN_MACRO(en_minus,  MINUS)
    EN_MACRO(en_ast,    ASTERISK)
    EN_MACRO(en_pct,    PERCENT)
    EN_MACRO(en_dollar, DOLLAR)
    EN_MACRO(en_tilde,  TILDE)
    EN_MACRO(en_lpar,   LPAR)
    EN_MACRO(en_rpar,   RPAR)
    EN_MACRO(en_lbrc,   LEFT_BRACE)
    EN_MACRO(en_rbrc,   RIGHT_BRACE)
