// EIJI 切替 → 数字 / 記号キー用の専用 behavior 群
// macros { } ブロック内に #include して使う

    // EIJI 切替 → 数字キー（NUM_LAYER 用）
    en0: en0 { // 0
      compatible = "zmk,behavior-macro";
      #binding-cells = <0>;
      bindings = <&macro_tap &kp EIJI>, <&macro_press &kp N0>, <&macro_pause_for_release>, <&macro_release &kp N0>;
    };
    en1: en1 { // 1
      compatible = "zmk,behavior-macro";
      #binding-cells = <0>;
      bindings = <&macro_tap &kp EIJI>, <&macro_press &kp N1>, <&macro_pause_for_release>, <&macro_release &kp N1>;
    };
